{
  "routes": [
    {
      "src": "/index.js",
      "dest": "/index.js",
      "headers": {
        "Content-Type": "text/javascript; charset=utf-8",
        "X-Planner-Route-Debug": "Served-Index-JS-Via-Explicit-Route"
      }
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/$1.js",
      "headers": {
        "Content-Type": "text/javascript; charset=utf-8"
      }
    },
    {
      "src": "/(.*\\.ts)",
      "dest": "/$1.ts",
      "headers": {
        "Content-Type": "text/javascript; charset=utf-8"
      }
    },
    {
      "src": "/(.*\\.tsx)",
      "dest": "/$1.tsx",
      "headers": {
        "Content-Type": "text/javascript; charset=utf-8"
      }
    }
  ]
}
